---
import BaseLayout from '../layouts/BaseLayout.astro';

const menu = [
  ['01. Humo & Especias', 'Mezcal artesanal, licor de chile ancho, sirope de agave tostado y bitter de cacao.'],
  ['02. Velvet Martini', 'Vodka infusionado en vainilla, vermut seco y un toque de aceite de oliva.'],
  ['03. Noche Eterna', 'Ginebra botánica, licor de flor de saúco, pepino fresco y tónica premium.']
];

const gallery = [
  'https://images.unsplash.com/photo-1470337458703-46ad1756a187?auto=format&fit=crop&w=1024&q=70',
  'https://images.unsplash.com/photo-1516997121675-4c2d1684aa3e?auto=format&fit=crop&w=1024&q=70'
];

const heroImage = 'https://images.unsplash.com/photo-1566417713940-fe7c737a9ef2?auto=format&fit=crop&w=1400&q=70';
const buildSrcSet = (url: string, widths: number[], quality = 70) =>
  widths
    .map((width) => `${url.replace(/w=\d+/, `w=${width}`).replace(/q=\d+/, `q=${quality}`)} ${width}w`)
    .join(', ');
---

<BaseLayout
  title="Fuego | Underground Cinematic"
  description="Demo de bar con estética nocturna y cinemática."
  path="/bar"
>
  <div class="cinematic-container">
    
    <section class="cinematic-hero animate-reveal">
      <div class="hero-bg">
        <img src={heroImage} srcset={buildSrcSet(heroImage, [480, 768, 1024, 1400], 68)} sizes="100vw" alt="Bar Atmosphere" class="hero-image" width="1400" height="933" loading="eager" decoding="async" fetchpriority="high" />
        <div class="hero-vignette"></div>
      </div>
      
      <div class="hero-content">
        <span class="text-eyebrow neon-glow">Vol. 1 — La Noche</span>
        <h1 class="text-huge">Fuego.</h1>
        <p class="hero-desc">Un refugio subterráneo donde el tiempo se detiene. Mixología experimental, vinilos y penumbra.</p>
        <a href="#reservar" class="btn-avant btn-neon">Reservar Mesa</a>
      </div>
    </section>

    <section class="cinematic-menu">
      <div class="menu-intro">
        <h2 class="text-display italic">Líquido<br/>& Humo.</h2>
      </div>
      <div class="menu-items">
        {menu.map(([title, desc]) => (
          <article class="menu-card">
            <h3>{title}</h3>
            <p>{desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="cinematic-gallery">
      {gallery.map(img => (
        <div class="gallery-frame">
          <img src={img} srcset={buildSrcSet(img, [480, 768, 960, 1024], 68)} sizes="(max-width: 900px) 100vw, 50vw" alt="Momentos" loading="lazy" decoding="async" width="1024" height="683" />
        </div>
      ))}
    </section>

    <section class="cinematic-booking" id="reservar">
      <div class="booking-glass">
        <h2 class="text-display">Asegura<br/>Tu Sitio.</h2>
        <p id="bar-demo-form-note" class="sr-only">Formulario de demostración. No envía datos reales.</p>
        <form class="minimal-form dark-form" data-demo-form aria-describedby="bar-demo-form-note" novalidate>
          <div class="field-group">
            <label class="sr-only" for="bar-nombre">Responsable de la reserva</label>
            <input id="bar-nombre" type="text" name="nombre" placeholder="Responsable de la reserva" autocomplete="name" />
          </div>
          <div class="field-group">
            <label class="sr-only" for="bar-personas">Número de personas</label>
            <select id="bar-personas" name="personas" autocomplete="off">
              <option>2 Personas</option>
              <option>4 Personas</option>
              <option>Grupo (+6)</option>
            </select>
          </div>
          <div class="field-group">
            <label class="sr-only" for="bar-hora">Hora</label>
            <input id="bar-hora" type="time" name="hora" />
          </div>
          <button class="btn-avant btn-neon" type="submit">Confirmar</button>
        </form>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .cinematic-container {
    width: 100%;
    color: var(--color-text);
  }

  /* Hero */
  .cinematic-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100svh;
    display: flex;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 6rem 4rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.2) brightness(0.6);
  }

  .hero-vignette {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 0%, rgba(9, 9, 11, 0.5) 40%, rgba(9, 9, 11, 0.95) 100%),
                radial-gradient(circle at 60% 40%, transparent 20%, rgba(9, 9, 11, 0.8) 100%);
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: left;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.5rem;
    max-width: 800px;
  }

  .neon-glow {
    color: var(--color-accent);
    text-shadow: 0 0 10px rgba(255, 106, 61, 0.5);
  }

  .hero-content h1 {
    color: #fff;
    text-shadow: 0 0 40px rgba(255, 255, 255, 0.2);
  }

  .hero-desc {
    font-size: 1.35rem;
    max-width: 600px;
    color: rgba(255, 255, 255, 0.85);
    line-height: 1.6;
    text-shadow: 0 4px 12px rgba(0, 0, 0, 0.6);
  }

  .btn-neon {
    background: var(--color-accent);
    color: #000;
    box-shadow: 0 0 20px rgba(255, 106, 61, 0.4);
  }

  .btn-neon:hover {
    background: #fff;
    color: #000;
    box-shadow: 0 0 30px rgba(255, 255, 255, 0.6);
  }

  /* Menu */
  .cinematic-menu {
    padding: 10rem 2.5rem;
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 4rem;
  }

  .menu-intro {
    position: sticky;
    top: 10rem;
    align-self: start;
  }

  .menu-items {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .menu-card {
    padding: 3rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    backdrop-filter: blur(20px);
    transition: transform 400ms var(--ease-out), border-color 400ms var(--ease-out);
  }

  .menu-card:hover {
    transform: translateX(10px);
    border-color: rgba(255, 106, 61, 0.3);
  }

  .menu-card h3 {
    font-size: 1.5rem;
    font-family: var(--font-mono);
    margin-bottom: 1rem;
    color: #fff;
  }

  .menu-card p {
    color: var(--color-muted);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  /* Gallery */
  .cinematic-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
    padding: 0 2.5rem 10rem;
    max-width: 1400px;
    margin: auto;
  }

  .gallery-frame img {
    height: 600px;
    width: 100%;
    object-fit: cover;
    border-radius: 20px;
    filter: brightness(0.7);
    transition: filter 400ms;
  }

  .gallery-frame:hover img {
    filter: brightness(1.1);
  }

  /* Booking */
  .cinematic-booking {
    padding: 10rem 2.5rem;
    background-image: url('https://images.unsplash.com/photo-1514933651103-005eec06c04b?auto=format&fit=crop&w=960&q=65');
    background-image: image-set(
      url('https://images.unsplash.com/photo-1514933651103-005eec06c04b?auto=format&fit=crop&w=960&q=65') 1x,
      url('https://images.unsplash.com/photo-1514933651103-005eec06c04b?auto=format&fit=crop&w=1400&q=70') 2x
    );
    background-position: center;
    background-size: cover;
    position: relative;
    display: flex;
    justify-content: center;
  }

  .cinematic-booking::before {
    content: '';
    position: absolute;
    inset: 0;
    background: rgba(9, 9, 11, 0.85);
  }

  .booking-glass {
    position: relative;
    z-index: 1;
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(30px);
    padding: 5rem;
    border-radius: 30px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    max-width: 600px;
    width: 100%;
    text-align: center;
  }

  .booking-glass h2 {
    margin-bottom: 3rem;
  }

  .dark-form input, .dark-form select {
    text-align: center;
  }

  @media (max-width: 900px) {
    .cinematic-menu {
      grid-template-columns: 1fr;
    }
    .menu-intro {
      position: static;
    }
    .cinematic-gallery {
      grid-template-columns: 1fr;
    }
    .booking-glass {
      padding: 3rem 2rem;
    }
  }

  @media (max-width: 600px) {
    .cinematic-hero {
      padding: 8rem 1.5rem 4rem;
    }
    .cinematic-menu {
      padding: 5rem 1.5rem;
    }
    .menu-card {
      padding: 2rem 1.5rem;
    }
    .cinematic-gallery {
      padding: 0 1.5rem 5rem;
    }
    .gallery-frame img {
      height: 400px;
    }
    .cinematic-booking {
      padding: 5rem 1.5rem;
    }
    .booking-glass {
      padding: 2.5rem 1.5rem;
    }
  }
</style>
