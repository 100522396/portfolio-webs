---
import BaseLayout from '../layouts/BaseLayout.astro';

const demos = [
  {
    path: '/peluqueria',
    number: '01',
    title: 'Peluqueria',
    subtitle: 'Editorial. Sofisticada.',
    image: 'https://images.unsplash.com/photo-1562322140-8baeececf3df?auto=format&fit=crop&w=1400&q=70'
  },
  {
    path: '/bar',
    number: '02',
    title: 'Bar Fuego',
    subtitle: 'Atmosfera. Noche.',
    image: 'https://images.unsplash.com/photo-1514933651103-005eec06c04b?auto=format&fit=crop&w=1400&q=70'
  },
  {
    path: '/fisioterapia',
    number: '03',
    title: 'Clinica',
    subtitle: 'Serena. Humana.',
    image: 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?auto=format&fit=crop&w=1400&q=70'
  }
];

const defaultBg = "https://images.unsplash.com/photo-1513694203232-719a280e022f?auto=format&fit=crop&w=1400&q=70";
const transparentPixel = 'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///ywAAAAAAQABAAACAUwAOw==';
const buildSrcSet = (url: string, widths: number[], quality = 70) =>
  widths
    .map((width) => `${url.replace(/w=\d+/, `w=${width}`).replace(/q=\d+/, `q=${quality}`)} ${width}w`)
    .join(', ');
---

<BaseLayout
  title="Zarenillas | The Curated Exhibition"
  description="Portfolio de demos para webs de alto impacto visual."
  path="/"
>
  <div class="hub-exhibition">
    <div class="background-reveals" aria-hidden="true">
      <img src={defaultBg} srcset={buildSrcSet(defaultBg, [480, 768, 1024, 1400])} sizes="100vw" alt="" id="bg-default" class="demo-bg is-active" loading="eager" decoding="async" fetchpriority="high" />
      {demos.map((demo, i) => (
        <img src={transparentPixel} data-src={demo.image} data-srcset={buildSrcSet(demo.image, [480, 768, 1024, 1400])} sizes="100vw" alt="" id={`bg-${i}`} class="demo-bg" loading="lazy" decoding="async" fetchpriority="low" />
      ))}
      <div class="bg-overlay"></div>
    </div>

    <div class="hub-content">
      <header class="hub-intro animate-reveal">
        <span class="text-eyebrow">Portfolio de Arquitectura Visual</span>
        <h1 class="text-display italic">Curated <br/>Exhibition.</h1>
        <p class="hub-desc">Explora tres aproximaciones de diseño asimétrico y vanguardista para negocios locales.</p>
      </header>

      <nav class="hub-menu animate-reveal" style="animation-delay: 200ms;" aria-label="Demos disponibles">
        {demos.map((demo, i) => (
          <a href={demo.path} class="menu-item" data-index={i}>
            <span class="menu-number">{demo.number}</span>
            <span class="text-huge menu-title">{demo.title}</span>
            <span class="menu-subtitle">{demo.subtitle}</span>
          </a>
        ))}
      </nav>
      

    </div>
  </div>
</BaseLayout>

<script>
  const menu = document.querySelector('.hub-menu');
  const items = document.querySelectorAll('.menu-item');
  const bgs = document.querySelectorAll('.demo-bg');
  const defaultBgImg = document.getElementById('bg-default');

  const setActiveBg = (idx) => {
    bgs.forEach((bg) => bg.classList.remove('is-active'));
    const activeBg = document.getElementById(`bg-${idx}`);
    if (!activeBg) return;

    if (activeBg instanceof HTMLImageElement && activeBg.dataset.loaded !== 'true') {
      if (activeBg.dataset.src) activeBg.src = activeBg.dataset.src;
      if (activeBg.dataset.srcset) activeBg.srcset = activeBg.dataset.srcset;
      activeBg.dataset.loaded = 'true';
    }

    activeBg.classList.add('is-active');
  };

  const setDefaultBg = () => {
    bgs.forEach((bg) => bg.classList.remove('is-active'));
    if (defaultBgImg) defaultBgImg.classList.add('is-active');
  };
  
  items.forEach((item) => {
    const idx = item.getAttribute('data-index');
    if (!idx) return;

    item.addEventListener('mouseenter', () => {
      setActiveBg(idx);
    });

    item.addEventListener('focus', () => {
      setActiveBg(idx);
    });

    item.addEventListener('touchstart', () => {
      setActiveBg(idx);
    });
  });
  
  if (menu) {
    menu.addEventListener('mouseleave', () => {
      setDefaultBg();
    });

    menu.addEventListener('focusout', (event) => {
      if (!menu.contains(event.relatedTarget)) {
        setDefaultBg();
      }
    });
  }
</script>

<style is:global>
  .hub-exhibition {
    min-height: 100vh;
    min-height: 100svh;
    padding: 10rem 2.5rem 4rem;
    position: relative;
    display: grid;
    grid-template-columns: 1fr;
  }

  .background-reveals {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background: var(--color-bg);
  }

  .demo-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.05);
    transition: opacity 800ms var(--ease-out), transform 4s var(--ease-out);
    filter: grayscale(80%) contrast(1.2);
  }

  .demo-bg.is-active {
    opacity: 0.35;
    transform: scale(1);
    filter: grayscale(30%) contrast(1.1);
  }

  .bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(9, 9, 11, 0.5) 0%, rgba(9, 9, 11, 0.95) 100%);
  }

  .hub-content {
    display: grid;
    gap: 5rem;
    max-width: 1800px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 2;
  }

  .hub-intro {
    max-width: 600px;
  }

  .hub-intro h1 {
    margin: 1.5rem 0 2rem;
  }

  .hub-desc {
    font-size: 1.25rem;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 440px;
  }

  .hub-menu {
    display: flex;
    flex-direction: column;
  }

  .menu-item {
    display: grid;
    grid-template-columns: 100px 1fr 200px;
    align-items: center;
    padding: 3.5rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: padding 600ms var(--ease-expo), color 400ms var(--ease-out), border-color 600ms var(--ease-out);
    color: var(--color-muted);
  }

  .menu-item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .menu-number {
    font-family: var(--font-mono);
    font-size: 1.5rem;
    font-weight: 300;
    opacity: 0.6;
  }

  .menu-title {
    transition: transform 600ms var(--ease-expo), color 400ms var(--ease-out), letter-spacing 600ms var(--ease-expo);
    transform-origin: left center;
  }

  .menu-subtitle {
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    opacity: 0;
    transform: translateX(-20px);
    transition: all 400ms var(--ease-out);
  }

  .menu-item:hover {
    color: var(--color-text);
    padding-left: 3rem;
    padding-right: 3rem;
    border-color: rgba(255, 255, 255, 0.4);
  }

  .menu-item:hover .menu-title {
    transform: translateX(30px);
    letter-spacing: -0.04em;
    color: #fff;
  }

  .menu-item:hover .menu-subtitle {
    opacity: 1;
    transform: translateX(0);
  }

  .hub-footer {
    display: flex;
    justify-content: flex-end;
    padding-top: 2rem;
  }

  @media (max-width: 1024px) {
    .menu-item {
      grid-template-columns: 60px 1fr;
      gap: 1rem;
      padding: 2.5rem 0;
    }
    .menu-subtitle {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .hub-exhibition {
      padding: 10rem 1.5rem 3rem;
    }
    .hub-content {
      gap: 3rem;
    }
    .menu-item {
      padding: 2rem 0;
      grid-template-columns: 1fr;
      gap: 0.5rem;
    }
    .menu-number {
      font-size: 1rem;
    }
    .menu-item:hover {
      padding-left: 0;
      padding-right: 0;
    }
    .menu-item:hover .menu-title {
      transform: translateX(10px);
    }
  }
</style>
