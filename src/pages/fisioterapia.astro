---
import BaseLayout from '../layouts/BaseLayout.astro';

const treatments = [
  ['01', 'Movilidad', 'Terapias manuales orientadas a recuperar la amplitud de movimiento articular y aliviar tensiones estructurales profundas.'],
  ['02', 'Readaptación', 'Protocolos biomecánicos específicos para devolver al sistema musculoesquelético su fuerza natural tras una lesión.'],
  ['03', 'Rendimiento', 'Análisis cinemático y ajuste de cargas para optimizar la eficiencia motriz en atletas y minimizar riesgos.']
];

const heroImage = 'https://images.unsplash.com/photo-1576091160399-112ba8d25d1d?auto=format&fit=crop&w=1200&q=70';
const bookingImage = 'https://images.unsplash.com/photo-1530026405186-ed1f139313f8?auto=format&fit=crop&w=1200&q=70';
const buildSrcSet = (url: string, widths: number[], quality = 70) =>
  widths
    .map((width) => `${url.replace(/w=\d+/, `w=${width}`).replace(/q=\d+/, `q=${quality}`)} ${width}w`)
    .join(', ');
---

<BaseLayout
  title="Clínica Serena | Architectural Anatomy"
  description="Demo de clínica de fisioterapia con diseño estructurado y clínico."
  path="/fisioterapia"
>
  <div class="anatomy-container">
    
    <div class="blueprint-grid">
      
      <!-- HERO -->
      <section class="blueprint-hero animate-reveal">
        <div class="hero-data">
          <div class="data-block">
            <span class="data-label">Instalación</span>
            <span class="data-value">CS-01 // Valencia</span>
          </div>
          <div class="data-block">
            <span class="data-label">Especialidad</span>
            <span class="data-value">Ingeniería Corporal</span>
          </div>
          <div class="hero-title-box">
            <h1 class="text-blueprint">Sistemas<br/>Mecánico-<br/>Humanos.</h1>
            <p class="hero-desc">La fisioterapia entendida como arquitectura clínica. Diagnosticamos, calibramos y optimizamos la estructura de soporte para un movimiento perfecto.</p>
            <a href="#analisis" class="btn-avant btn-blueprint">Solicitar Análisis</a>
          </div>
        </div>
        <div class="hero-visual">
          <div class="precision-frame">
            <div class="crosshair top-left"></div>
            <div class="crosshair top-right"></div>
            <div class="crosshair bottom-left"></div>
            <div class="crosshair bottom-right"></div>
            <img src={heroImage} srcset={buildSrcSet(heroImage, [480, 768, 960, 1200], 68)} sizes="(max-width: 1024px) 100vw, 50vw" alt="Diagnóstico Clínico" loading="eager" decoding="async" fetchpriority="high" width="1200" height="800" />
          </div>
        </div>
      </section>

      <!-- SERVICES / TREATMENTS -->
      <section class="blueprint-treatments">
        <div class="section-badge">
          <span class="text-eyebrow">Protocolos de Intervención</span>
        </div>
        <h2 class="sr-only">Tratamientos disponibles</h2>
        <div class="treatments-table">
          {treatments.map(([num, title, desc]) => (
            <article class="table-row">
              <div class="row-num">{num}</div>
              <h3 class="row-title">{title}</h3>
              <p class="row-desc">{desc}</p>
            </article>
          ))}
        </div>
      </section>

      <!-- BOOKING -->
      <section class="blueprint-booking" id="analisis">
        <div class="booking-grid">
          <div class="booking-blueprint">
            <img src={bookingImage} srcset={buildSrcSet(bookingImage, [480, 768, 960, 1200], 68)} sizes="(max-width: 1024px) 100vw, 50vw" alt="Estructura y alineación" loading="lazy" decoding="async" width="1200" height="1800" />
          </div>
          <div class="booking-form-area">
            <h2 class="text-blueprint">Inicia<br/>Secuencia.</h2>
            <p id="fisioterapia-demo-form-note" class="sr-only">Formulario de demostración. No envía datos reales.</p>
            <form class="minimal-form blueprint-form" data-demo-form aria-describedby="fisioterapia-demo-form-note" novalidate>
              <div class="field-row">
                <label class="sr-only" for="fisioterapia-paciente">ID Paciente o Nombre</label>
                <input id="fisioterapia-paciente" type="text" name="paciente" placeholder="ID Paciente / Nombre" autocomplete="name" />
              </div>
              <div class="field-row">
                <label class="sr-only" for="fisioterapia-objetivo">Protocolo</label>
                <select id="fisioterapia-objetivo" name="objetivo" autocomplete="off">
                  <option>Seleccionar Protocolo</option>
                  <option>Evaluación Estructural</option>
                  <option>Intervención de Dolor</option>
                  <option>Ajuste de Rendimiento</option>
                </select>
              </div>
              <div class="field-row">
                <label class="sr-only" for="fisioterapia-fecha">Fecha</label>
                <input id="fisioterapia-fecha" type="date" name="fecha" />
              </div>
              <button class="btn-avant btn-blueprint" type="submit">Procesar Clínica</button>
            </form>
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .anatomy-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 10rem 2.5rem 4rem;
  }

  .blueprint-grid {
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
  }

  /* Hero */
  .blueprint-hero {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid var(--color-border);
  }

  .hero-data {
    display: flex;
    flex-direction: column;
    border-right: 1px solid var(--color-border);
  }

  .data-block {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    text-transform: uppercase;
    font-size: 0.85rem;
    letter-spacing: 0.1em;
  }

  .data-label { color: var(--color-muted); }
  .data-value { color: var(--color-accent); font-weight: 600; }

  .hero-title-box {
    padding: 6rem 4rem;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 3rem;
  }

  .hero-desc {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-muted);
    max-width: 400px;
  }

  .btn-blueprint {
    align-self: flex-start;
    background: transparent;
    border: 1px solid var(--color-border);
    color: var(--color-text);
  }

  .btn-blueprint:hover {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .hero-visual {
    padding: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: repeating-linear-gradient(0deg, transparent, transparent 39px, rgba(0,0,0,0.03) 40px),
                repeating-linear-gradient(90deg, transparent, transparent 39px, rgba(0,0,0,0.03) 40px);
  }

  .precision-frame {
    position: relative;
    width: 100%;
    max-width: 450px;
    aspect-ratio: 3/4;
    border: 1px solid var(--color-accent);
    padding: 1rem;
    background: rgba(0,0,0,0.02);
  }

  .precision-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 600ms var(--ease-out);
  }

  .precision-frame:hover img {
    transform: scale(1.02);
  }

  .crosshair {
    position: absolute;
    width: 12px;
    height: 12px;
    border: 1px solid var(--color-accent);
  }
  .top-left { top: -6px; left: -6px; border-right: none; border-bottom: none; }
  .top-right { top: -6px; right: -6px; border-left: none; border-bottom: none; }
  .bottom-left { bottom: -6px; left: -6px; border-right: none; border-top: none; }
  .bottom-right { bottom: -6px; right: -6px; border-left: none; border-top: none; }

  /* Treatments */
  .blueprint-treatments {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid var(--color-border);
  }

  .section-badge {
    padding: 1.5rem 2.5rem;
    border-bottom: 1px solid var(--color-border);
  }

  .treatments-table {
    display: flex;
    flex-direction: column;
  }

  .table-row {
    display: grid;
    grid-template-columns: 80px 300px 1fr;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    padding: 3rem 2.5rem;
    transition: background 400ms;
  }

  .table-row:last-child {
    border-bottom: none;
  }

  .table-row:hover {
    background: rgba(0, 0, 0, 0.02);
  }

  .row-num {
    font-family: var(--font-mono);
    color: var(--color-accent);
    font-size: 1.5rem;
    font-weight: 300;
  }

  .row-title {
    font-family: var(--font-sans);
    font-size: 2rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }

  .row-desc {
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 600px;
    font-size: 1.1rem;
  }

  /* Booking */
  .blueprint-booking {
    display: grid;
    grid-template-columns: 1fr;
  }

  .booking-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
  }

  .booking-blueprint {
    border-right: 1px solid var(--color-border);
    padding: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .booking-blueprint img {
    border: 1px solid var(--color-border);
    width: 100%;
    max-width: 400px;
  }

  .booking-form-area {
    padding: 6rem 4rem;
    display: flex;
    flex-direction: column;
    gap: 4rem;
  }

  .blueprint-form .field-row {
    border-bottom: 1px solid var(--color-border);
  }

  .blueprint-form input,
  .blueprint-form select {
    border: none !important;
    background: transparent !important;
    padding: 1.5rem 0 !important;
    font-family: var(--font-mono) !important;
    text-transform: uppercase;
    font-size: 0.9rem !important;
    letter-spacing: 0.1em;
  }

  .blueprint-form input:focus,
  .blueprint-form select:focus {
    color: var(--color-accent) !important;
    border-color: var(--color-accent) !important;
  }

  @media (max-width: 1024px) {
    .blueprint-hero, .booking-grid {
      grid-template-columns: 1fr;
    }
    .hero-data, .booking-blueprint {
      border-right: none;
      border-bottom: 1px solid var(--color-border);
    }
    .table-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .row-num {
      margin-bottom: 1rem;
    }
    .hero-visual {
      padding: 2rem;
    }
    .hero-title-box, .booking-form-area {
      padding: 3rem 2rem;
    }
  }

  @media (max-width: 600px) {
    .anatomy-container {
      padding: 8rem 1.5rem 3rem;
    }
    .hero-title-box, .booking-form-area {
      padding: 2rem 1.5rem;
      gap: 2rem;
    }
    .data-block {
      padding: 1.5rem;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
    }
    .table-row {
      padding: 2rem 1.5rem;
    }
    .section-badge {
      padding: 1.5rem;
    }
  }
</style>
