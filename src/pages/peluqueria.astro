---
import BaseLayout from '../layouts/BaseLayout.astro';

const services = [
  ['01. Corte Signature', 'Diagnóstico de visagismo, lavado sensorial y acabado arquitectónico. Un estudio de tus proporciones para un resultado duradero y sin esfuerzo diario.'],
  ['02. Color Atelier', 'Balayage, gloss y correcciones con enfoque en luz, contraste y naturalidad absoluta.'],
  ['03. Ritual Evento', 'Peinado, textura pura y maquillaje editorial para ocasiones donde la presencia importa.']
];

const gallery = [
  'https://images.unsplash.com/photo-1521590832167-7bcbfaa6381f?auto=format&fit=crop&w=1024&q=70',
  'https://images.unsplash.com/photo-1487412912498-0447578fcca8?auto=format&fit=crop&w=1024&q=70',
  'https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=1024&q=70'
];

const heroImage = 'https://images.unsplash.com/photo-1560066984-138dadb4c035?auto=format&fit=crop&w=1400&q=70';
const buildSrcSet = (url: string, widths: number[], quality = 70) =>
  widths
    .map((width) => `${url.replace(/w=\d+/, `w=${width}`).replace(/q=\d+/, `q=${quality}`)} ${width}w`)
    .join(', ');
---

<BaseLayout
  title="Atelier Norte | High Fashion Editorial"
  description="Demo de peluquería vanguardista."
  path="/peluqueria"
>
  <div class="editorial-container">
    
    <section class="editorial-hero animate-reveal">
      <div class="hero-image-wrap">
        <img src={heroImage} srcset={buildSrcSet(heroImage, [480, 768, 1024, 1400])} sizes="(max-width: 1024px) 100vw, 55vw" alt="Salon Editorial" class="hero-image" width="1400" height="933" loading="eager" decoding="async" fetchpriority="high" />
      </div>
      <div class="hero-text-block">
        <span class="text-eyebrow">Atelier Norte</span>
        <h1 class="text-display italic">La forma<br/>sigue a la<br/>identidad.</h1>
        <div class="hero-details">
          <p>Un salón donde el cabello se trata como materia escultórica. Cortes limpios, color calculado y estética utilitaria con alma premium.</p>
          <a class="btn-avant" href="#reserva">Reservar Cita</a>
        </div>
      </div>
    </section>

    <section class="editorial-manifesto">
      <div class="manifesto-grid">
        <div class="manifesto-lead">
          <h2 class="text-huge">01.<br/>Vision.</h2>
        </div>
        <div class="manifesto-body">
          <p>Atelier Norte rechaza el ornamento innecesario. Creemos en la funcionalidad de un buen corte y en la química exacta de un color que evoluciona maravillosamente con el tiempo. Nuestro equipo actúa como curador de tu estilo personal.</p>
        </div>
      </div>
    </section>

    <section class="editorial-services">
      <div class="services-header">
        <h2 class="text-display">Servicios<br/>Curation.</h2>
      </div>
      <div class="services-list">
        {services.map(([title, desc]) => (
          <article class="service-row">
            <h3 class="service-title">{title}</h3>
            <p class="service-desc">{desc}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="editorial-gallery">
      {gallery.map((img, i) => (
        <div class={`gallery-item item-${i}`}>
          <img src={img} srcset={buildSrcSet(img, [480, 768, 960, 1024], 68)} sizes="100vw" alt="Estilo Atelier" loading="lazy" decoding="async" width="1024" height="683" />
        </div>
      ))}
    </section>

    <section class="editorial-booking" id="reserva">
      <div class="booking-grid">
        <div class="booking-context">
          <span class="text-eyebrow">RSVP</span>
          <h2 class="text-display">Solicitar<br/>Espacio.</h2>
          <p>La disponibilidad es limitada. Reserva previa necesaria para todos los servicios curatoriales.</p>
        </div>
        <div class="booking-form-wrap">
          <p id="peluqueria-demo-form-note" class="sr-only">Formulario de demostración. No envía datos reales.</p>
          <form class="minimal-form" data-demo-form aria-describedby="peluqueria-demo-form-note" novalidate>
            <div class="field-group">
              <label for="peluqueria-nombre">Identidad</label>
              <input id="peluqueria-nombre" type="text" name="nombre" placeholder="Nombre completo" autocomplete="name" />
            </div>
            <div class="field-group">
              <label for="peluqueria-telefono">Contacto</label>
              <input id="peluqueria-telefono" type="tel" name="telefono" placeholder="Teléfono" autocomplete="tel" inputmode="tel" />
            </div>
            <div class="field-group">
              <label for="peluqueria-servicio">Interés</label>
              <select id="peluqueria-servicio" name="servicio" autocomplete="off">
                <option>01. Corte Signature</option>
                <option>02. Color Atelier</option>
                <option>03. Ritual Evento</option>
              </select>
            </div>
            <div class="field-group">
              <label for="peluqueria-mensaje">Visión</label>
              <textarea id="peluqueria-mensaje" name="mensaje" placeholder="Cuéntanos brevemente qué buscas proyectar..." autocomplete="off"></textarea>
            </div>
            <button class="btn-avant" type="submit">Contactar Atelier</button>
          </form>
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .editorial-container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 10rem 2.5rem 5rem;
  }

  /* Hero */
  .editorial-hero {
    display: grid;
    grid-template-columns: 55% 1fr;
    gap: 4rem;
    align-items: center;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 6rem;
  }

  .hero-image-wrap {
    overflow: hidden;
    height: 80vh;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter 800ms var(--ease-out), transform 3s var(--ease-out);
    transform: scale(1.05);
  }

  .hero-image-wrap:hover .hero-image {
    filter: grayscale(0%);
    transform: scale(1);
  }

  .hero-text-block {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .hero-details {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 3rem;
  }

  .hero-details p {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-muted);
    max-width: 320px;
  }

  /* Manifesto */
  .editorial-manifesto {
    padding: 8rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .manifesto-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
  }

  .manifesto-body p {
    font-size: 2rem;
    line-height: 1.4;
    font-family: var(--font-serif);
    font-weight: 300;
  }

  /* Services */
  .editorial-services {
    padding: 8rem 0;
    display: grid;
    grid-template-columns: 40% 1fr;
    gap: 4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .service-row {
    padding: 3rem 0;
    border-bottom: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 1fr 1.5fr;
    gap: 2rem;
    align-items: start;
  }

  .service-row:first-child {
    padding-top: 0;
  }

  .service-row:last-child {
    border-bottom: none;
    padding-bottom: 0;
  }

  .service-title {
    font-family: var(--font-mono);
    font-size: 1.25rem;
    font-weight: 600;
  }

  .service-desc {
    font-size: 1.1rem;
    color: var(--color-muted);
    line-height: 1.6;
  }

  /* Gallery Asymmetric */
  .editorial-gallery {
    padding: 8rem 0;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .gallery-item {
    overflow: hidden;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter 600ms;
  }
  
  .gallery-item:hover img {
    filter: grayscale(0%);
  }

  .item-0 { grid-column: 1 / 7; height: 600px; }
  .item-1 { grid-column: 8 / 13; height: 800px; margin-top: -100px; }
  .item-2 { grid-column: 3 / 10; height: 500px; margin-top: 4rem; }

  /* Booking */
  .editorial-booking {
    padding: 8rem 0 4rem;
  }

  .booking-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
  }

  .booking-context {
    position: sticky;
    top: 8rem;
    align-self: start;
  }

  .booking-context p {
    margin-top: 2rem;
    font-size: 1.25rem;
    color: var(--color-muted);
    line-height: 1.6;
    max-width: 400px;
  }

  @media (max-width: 1024px) {
    .editorial-hero {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .hero-image-wrap {
      height: 60vh;
      order: 2;
    }
    .hero-text-block {
      order: 1;
    }
    .manifesto-grid, .editorial-services, .booking-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .booking-context {
      position: static;
    }
    .item-0, .item-1, .item-2 {
      grid-column: 1 / -1;
      height: 400px;
      margin-top: 0;
    }
    .service-row {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
  }

  @media (max-width: 600px) {
    .editorial-container {
      padding: 8rem 1.5rem 3rem;
    }
    .editorial-hero {
      padding-bottom: 3rem;
    }
    .hero-image-wrap {
      height: 40vh;
    }
    .manifesto-body p {
      font-size: 1.5rem;
    }
    .editorial-manifesto, .editorial-services, .editorial-gallery, .editorial-booking {
      padding: 4rem 0;
    }
    .item-0, .item-1, .item-2 {
      height: 300px;
    }
  }
</style>
