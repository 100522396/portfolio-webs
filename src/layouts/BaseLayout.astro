---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  path?: string;
}

const { title, description, path = '/' } = Astro.props;
const canonical = new URL(path, Astro.site || 'http://localhost');
const isHub = path === '/';
const pathName = path === '/' ? 'hub' : path.replace('/', '');
const pageClass = `page-${pathName}`;

const navLinks = [
  { href: '/', label: 'Index' },
  { href: '/peluqueria', label: '01. Peluqueria' },
  { href: '/bar', label: '02. Bar' },
  { href: '/fisioterapia', label: '03. Clinica' }
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonical.toString()} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300..700;1,9..144,300..700&family=Manrope:wght@300;400;500;600;700&family=Outfit:wght@300;400;500;700;900&display=swap" rel="stylesheet" />
  </head>
  <body class={pageClass}>
    <header class="exhibition-header">
      <div class="header-inner">
        <a class="brand-avant" href="/">
          <span class="brand-dot"></span>
          Zarenillas
        </a>
        <nav class="pill-nav" aria-label="Navegacion">
          {navLinks.map((link) => (
            <a href={link.href} class:list={{ active: path === link.href }}>
              {link.label}
            </a>
          ))}
        </nav>
      </div>
    </header>
    <div class="grain-overlay"></div>
    <main class="smooth-content">
      <slot />
    </main>
  </body>
</html>
